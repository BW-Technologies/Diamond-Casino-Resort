rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction utilitaire pour verifier si l'utilisateur est connecté
    function isSignedIn() {
      return request.auth != null;
    }

    // Role helpers avec protection null-check
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'client';
    }
    
    function isPatron() {
      return isSignedIn() && getUserRole() == 'patron';
    }
    
    function isEmployeOrPatron() {
      return isSignedIn() && (getUserRole() == 'employe' || getUserRole() == 'patron');
    }

    // --------------------------------------------------------
    // RÈGLES DE SÉCURITÉ POUR CHAQUE COLLECTION
    // --------------------------------------------------------

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isPatron() || isEmployeOrPatron());
      allow delete: if isPatron();
    }

    match /storeItems/{itemId} {
      allow read: if true;
      allow write: if isPatron(); 
    }

    match /accounting/{transactionId} {
      allow read, write: if isEmployeOrPatron();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isPatron();
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn() && (request.auth.uid == chatId || isEmployeOrPatron());
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (request.auth.uid == chatId || isEmployeOrPatron());
      }
    }

    match /penthouseRequests/{requestId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isEmployeOrPatron());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isEmployeOrPatron());
      allow create: if isSignedIn();
      allow update: if isEmployeOrPatron();
      allow delete: if isEmployeOrPatron() || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
